# .env.example — copy to .env (gitignored) and fill in real values. One-time setup.
#
# Loaded automatically by:
#   npm run seed / npm run verify:rules   (node --env-file-if-exists=.env)
#   npm run verify:fresh                  (bash, sourced + exported)
# Variables already exported in your shell always take precedence over this file.

# PocketBase dashboard admin — separate from the app's `users` collection (SPEC §9).
SUPERUSER_EMAIL=you@example.com
SUPERUSER_PASSWORD='pick-a-strong-one'

# The two demo accounts (created by seed; used by rules-check as owner/other-user).
SEED_USER1_EMAIL=cece@stitches.local
SEED_USER1_PASSWORD='changeme-cece'
SEED_USER1_NAME=Cece
SEED_USER2_EMAIL=friend@stitches.local
SEED_USER2_PASSWORD='changeme-friend'
SEED_USER2_NAME=Friend

# Ravelry read-only app key (docs/RAVELRY.md §2) — used by the importer.
# The username identifies the app (not secret); the password is the secret half.
RAVELRY_BASIC_USER=read-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RAVELRY_BASIC='the-basic-auth-password'

# Cece's personal-access key (docs/RAVELRY.md §7) — used ONLY by scripts/ravelry-import.mjs.
# Full access to her Ravelry account: private channel only, and she deletes the app on
# Ravelry once the one-time import is done. Access key = username, *personal* key = password.
# RAVELRY_CECE_USER=her-access-key
# RAVELRY_CECE_KEY='her-personal-key'

# The PB account that will OWN the imported patterns (docs/ravelry-import-runbook.md) — also
# only read by scripts/ravelry-import.mjs. Locally this is usually SEED_USER1; against prod
# it's Cece's real account.
# RAVELRY_IMPORT_OWNER_EMAIL=cece@stitches.local
# RAVELRY_IMPORT_OWNER_PASSWORD='changeme-cece'

# Uncomment to point the scripts somewhere other than local dev (e.g. prod, Session 5.1).
# PB_URL=http://127.0.0.1:8090
