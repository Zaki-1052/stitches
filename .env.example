# .env.example — copy to .env (gitignored) and fill in real values. One-time setup.
#
# Loaded automatically by:
#   npm run seed / npm run verify:rules   (node --env-file-if-missing=.env)
#   npm run verify:fresh                  (bash, sourced + exported)
# Variables already exported in your shell always take precedence over this file.

# PocketBase dashboard admin — separate from the app's `users` collection (SPEC §9).
SUPERUSER_EMAIL=you@example.com
SUPERUSER_PASSWORD='pick-a-strong-one'

# The two demo accounts (created by seed; used by rules-check as owner/other-user).
SEED_USER1_EMAIL=cece@stitches.local
SEED_USER1_PASSWORD='changeme-cece'
SEED_USER1_NAME=Cece
SEED_USER2_EMAIL=friend@stitches.local
SEED_USER2_PASSWORD='changeme-friend'
SEED_USER2_NAME=Friend

# Uncomment to point the scripts somewhere other than local dev (e.g. prod, Session 5.1).
# PB_URL=http://127.0.0.1:8090
